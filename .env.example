# Generate with:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
LOCALCONTROL_API_KEY=replace-with-a-long-random-token

# Separate human approval key. Do not add this endpoint to your Custom GPT action schema.
LOCALCONTROL_APPROVAL_KEY=replace-with-a-different-long-random-token

LOCALCONTROL_BIND_HOST=127.0.0.1
LOCALCONTROL_PORT=8765
LOCALCONTROL_DATA_DIR=localcontrol-data
LOCALCONTROL_RATE_LIMIT_PER_MINUTE=120
LOCALCONTROL_MAX_RESPONSE_BYTES=65536
LOCALCONTROL_DEFAULT_SHELL_TIMEOUT_SECONDS=10
LOCALCONTROL_MAX_SYNC_SHELL_TIMEOUT_SECONDS=25
LOCALCONTROL_MAX_UNAPPROVED_SHELL_TIMEOUT_SECONDS=30
LOCALCONTROL_MAX_SEARCH_RESULTS=200
LOCALCONTROL_MAX_ARTIFACT_BYTES=52428800
LOCALCONTROL_MAX_TERMINAL_SESSIONS=5
LOCALCONTROL_TERMINAL_IDLE_TIMEOUT_SECONDS=1800
LOCALCONTROL_TERMINAL_EVENT_BUFFER_BYTES=1048576
